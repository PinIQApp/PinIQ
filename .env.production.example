ENVIRONMENT=production
APP_NAME=Pin IQ API
API_V1_STR=/api/v1
SECRET_KEY=replace-with-a-64-character-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_MINUTES=43200
DATABASE_URL=postgresql+psycopg://wrestletech:replace-db-password@db:5432/wrestletech
FRONTEND_ORIGIN=https://piniqapp.com
CORS_ORIGINS=https://piniqapp.com
MEDIA_DIR=media
AUTO_CREATE_SCHEMA=false
SEED_DEMO_DATA_ON_STARTUP=false
MAX_UPLOAD_SIZE_BYTES=5242880
ALLOWED_IMAGE_EXTENSIONS=.png,.jpg,.jpeg,.webp
AUTH_RATE_LIMIT_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
LOG_LEVEL=INFO
ENABLE_JSON_LOGS=true
MONITORING_WEBHOOK_URL=
MONITORING_WEBHOOK_TIMEOUT_SECONDS=5

SMS_PROVIDER=twilio
SMS_FROM_NUMBER=replace-with-twilio-from-number
SMS_TIMEOUT_SECONDS=5
TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token

EMAIL_PROVIDER=postmark
ALERT_EMAIL_FROM=Support@PinIQApp.com
EMAIL_TIMEOUT_SECONDS=5
POSTMARK_SERVER_TOKEN=replace-with-postmark-server-token

PUSH_PROVIDER=webhook
PUSH_WEBHOOK_URL=https://push-provider.example.com/webhook
PUSH_WEBHOOK_SECRET=replace-with-push-webhook-secret
PUSH_TIMEOUT_SECONDS=5

STORAGE_PROVIDER=s3
MEDIA_BASE_URL=https://cdn.piniqapp.com
S3_BUCKET_NAME=replace-with-bucket-name
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=replace-with-access-key
S3_SECRET_ACCESS_KEY=replace-with-secret-key
S3_PUBLIC_BASE_URL=https://cdn.piniqapp.com

PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_live_replace
STRIPE_PUBLISHABLE_KEY=pk_live_replace
STRIPE_WEBHOOK_SECRET=whsec_replace
CHECKOUT_SUCCESS_URL=https://piniqapp.com/store/success
CHECKOUT_CANCEL_URL=https://piniqapp.com/store/cancel

NUTRITION_PROVIDER=fitchef
FITCHEF_API_BASE=https://api.fitchef.example.com
FITCHEF_API_KEY=replace-with-fitchef-api-key
FITCHEF_CALLBACK_SECRET=replace-with-fitchef-callback-secret
PASSIO_API_BASE=
PASSIO_API_KEY=

ENABLE_STRICT_WRESTLER_SAFETY=true
TOURNAMENT_SCAN_TIMEOUT_SECONDS=15
TOURNAMENT_SCAN_USER_AGENT=PinIQTournamentScanner/1.0
FLO_EVENTS_URL=https://www.flowrestling.org/results
TRACK_EVENTS_URL=https://www.trackwrestling.com/Login.jsp?state=43
USA_BRACKETING_EVENTS_URL=https://www.usawmembership.com/usaw_results

POSTGRES_DB=wrestletech
POSTGRES_USER=wrestletech
POSTGRES_PASSWORD=replace-db-password
API_BASE_URL=https://api.piniqapp.com
