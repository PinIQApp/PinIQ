ENVIRONMENT=staging
APP_NAME=Pin IQ API
API_V1_STR=/api/v1
SECRET_KEY=replace-with-a-64-character-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_MINUTES=43200
DATABASE_URL=postgresql+psycopg://postgres:replace-password@db.example.supabase.co:5432/postgres
FRONTEND_ORIGIN=https://wrestletech-beta.onrender.com
CORS_ORIGINS=https://wrestletech-beta.onrender.com
MEDIA_DIR=media
AUTO_CREATE_SCHEMA=false
SEED_DEMO_DATA_ON_STARTUP=false
MAX_UPLOAD_SIZE_BYTES=5242880
ALLOWED_IMAGE_EXTENSIONS=.png,.jpg,.jpeg,.webp
AUTH_RATE_LIMIT_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
LOG_LEVEL=INFO
ENABLE_JSON_LOGS=true
MONITORING_WEBHOOK_URL=
MONITORING_WEBHOOK_TIMEOUT_SECONDS=5

SMS_PROVIDER=mock
SMS_FROM_NUMBER=
SMS_TIMEOUT_SECONDS=5
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

EMAIL_PROVIDER=mock
ALERT_EMAIL_FROM=
EMAIL_TIMEOUT_SECONDS=5
POSTMARK_SERVER_TOKEN=

PUSH_PROVIDER=mock
PUSH_WEBHOOK_URL=
PUSH_WEBHOOK_SECRET=
PUSH_TIMEOUT_SECONDS=5

STORAGE_PROVIDER=local
MEDIA_BASE_URL=/media
S3_BUCKET_NAME=
S3_REGION=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
CHECKOUT_SUCCESS_URL=https://wrestletech-beta.onrender.com/store/success
CHECKOUT_CANCEL_URL=https://wrestletech-beta.onrender.com/store/cancel

NUTRITION_PROVIDER=mock
FITCHEF_API_BASE=
FITCHEF_API_KEY=
FITCHEF_CALLBACK_SECRET=
PASSIO_API_BASE=
PASSIO_API_KEY=

ENABLE_STRICT_WRESTLER_SAFETY=true
TOURNAMENT_SCAN_TIMEOUT_SECONDS=15
TOURNAMENT_SCAN_USER_AGENT=PinIQTournamentScanner/1.0
FLO_EVENTS_URL=https://www.flowrestling.org/results
TRACK_EVENTS_URL=https://www.trackwrestling.com/Login.jsp?state=43
USA_BRACKETING_EVENTS_URL=https://www.usawmembership.com/usaw_results

API_BASE_URL=https://wrestletech-api.onrender.com
